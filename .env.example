# SAP Datasphere
DSP_CLIENT_ID=your-client-id
DSP_CLIENT_SECRET=your-client-secret
DSP_TOKEN_URL=https://<tenant>.authentication.<region>.hana.ondemand.com/oauth/token
DSP_BASE_URL=https://<tenant>.<region>.hcs.cloud.sap
DSP_SPACE_ID=PUBLIC_SECTOR
DSP_TECHNICAL_USER=your-technical-user

# SAP HANA Cloud (Direct)
HANA_HOST=your-instance.hana.prod-us10.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=PUBLIC_SECTOR#PUBLIC_SECTOR_WRITER
HANA_PASSWORD=your-password
HANA_SCHEMA=PUBLIC_SECTOR#PUBLIC_SECTOR_WRITER

# App
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
NODE_ENV=development
