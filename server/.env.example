# SAP HANA Cloud connection
HANA_HOST=your-hana-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=PUBLIC_SECTOR_WRITER
HANA_PASSWORD=your-password

# JWT signing secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-jwt-secret

# OpenAI
OPENAI_API_KEY=sk-...

# Port (Azure sets this automatically, default 4000 locally)
PORT=4000
